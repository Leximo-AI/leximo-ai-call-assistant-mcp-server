{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "leximo-ai-call-assistant",
  "description": "Leximo AI Call Assistant plugins for Claude Code",
  "owner": {
    "name": "Leximo AI",
    "email": "support@leximo.ai"
  },
  "plugins": [
    {
      "name": "leximo-ai-call-assistant",
      "description": "Make AI-powered phone calls — book reservations, schedule appointments, and view call transcripts",
      "version": "1.0.1",
      "author": {
        "name": "Leximo AI",
        "email": "support@leximo.ai"
      },
      "homepage": "https://concierge.leximo.ai",
      "repository": "https://github.com/Leximo-AI/leximo-ai-call-assistant-mcp-server",
      "license": "MIT",
      "keywords": ["mcp", "ai", "phone", "calls", "leximo", "automation", "voice"],
      "category": "productivity",
      "source": {
        "source": "npm",
        "package": "leximo-ai-call-assistant-mcp-server"
      },
      "strict": false,
      "mcpServers": {
        "leximo": {
          "command": "npx",
          "args": ["-y", "leximo-ai-call-assistant-mcp-server"],
          "env": {
            "LEXIMO_API_TOKEN": ""
          }
        }
      }
    }
  ]
}
